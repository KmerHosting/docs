{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "KmerHosting",
  "description": "Documentation for KmerHosting hosting products, customer operations, developer tools, and API integrations.",
  "colors": {
    "primary": "#1A73E8",
    "light": "#8AB4F8",
    "dark": "#1A73E8"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "favicon": "/images/favicon-192.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ],
    "display": "header"
  },
  "logo": {
    "light": "/images/logo-docs-light.png",
    "dark": "/images/logo-docs-dark.png",
    "href": "https://kmerhosting.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Console",
        "href": "https://console.kmerhosting.com"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/KmerHosting"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://kmerhosting.com"
        },
        {
          "anchor": "Console",
          "icon": "layout-dashboard",
          "href": "https://console.kmerhosting.com"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "https://kmerhosting.com/support"
        },
        {
          "anchor": "Status",
          "icon": "activity",
          "href": "https://status.kmerhosting.com"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "quickstart",
          "account/create-account",
          "account/email-verification",
          "account/kyc",
          "account/account-status"
        ]
      },
      {
        "group": "Products",
        "icon": "boxes",
        "expanded": true,
        "pages": [
          "products/shared-hosting",
          "products/vps",
          "products/domains",
          "products/custom-hosting",
          "products/kmerhosting-cli",
          "products/kmerhosting-forge",
          "products/kmerhosting-ai-agent",
          "products/kmerhosting-drive"
        ]
      },
      {
        "group": "Developer platform",
        "icon": "braces",
        "expanded": true,
        "pages": [
          "developer/overview",
          "developer/api-keys",
          "developer/sdk",
          "developer/cli",
          "developer/rest-api",
          "api/errors"
        ]
      },
      {
        "group": "API reference",
        "icon": "terminal",
        "openapi": {
          "source": "openapi.json",
          "directory": "api-reference"
        }
      },
      {
        "group": "Hosting guides",
        "icon": "server",
        "expanded": false,
        "pages": [
          "guides/deploy-website",
          "guides/shared-hosting-stacks",
          "guides/vps-stacks",
          "guides/dns-management",
          "guides/ssl-certificates",
          "guides/backups",
          "guides/email-configuration"
        ]
      },
      {
        "group": "Billing and customer operations",
        "icon": "wallet",
        "expanded": false,
        "pages": [
          "billing/overview",
          "billing/account-credit",
          "billing/orders",
          "billing/invoices",
          "billing/renewals",
          "billing/refunds",
          "guides/domain-availability",
          "guides/checkout",
          "guides/service-management",
          "guides/auto-renewal",
          "guides/support-ticket"
        ]
      },
      {
        "group": "Operations and troubleshooting",
        "icon": "wrench",
        "expanded": false,
        "pages": [
          "operations/status-page",
          "operations/incidents",
          "operations/maintenance",
          "troubleshooting/login",
          "troubleshooting/payment",
          "troubleshooting/domain-dns",
          "troubleshooting/vps-access",
          "troubleshooting/shared-hosting"
        ]
      },
      {
        "group": "Legal",
        "icon": "scale",
        "expanded": false,
        "pages": [
          "legal/terms",
          "legal/privacy",
          "legal/refund-policy",
          "legal/sla",
          "legal/cookie-policy",
          "legal/ai-usage-policy"
        ]
      }
    ]
  }
}
