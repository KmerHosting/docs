{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "KmerHosting",
  "description": "Customer, hosting, billing, and API documentation for KmerHosting.",
  "colors": {
    "primary": "#1A73E8",
    "light": "#8AB4F8",
    "dark": "#1A73E8"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "fonts": {
    "family": "Inter",
    "weight": 400,
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/images/logo-docs-light.png",
    "dark": "/images/logo-docs-dark.png",
    "href": "https://kmerhosting.com",
    "size": 56
  },
  "favicon": "/images/logo-mark.png",
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0A0A0A"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://kmerhosting.com"
      },
      {
        "label": "Pricing",
        "href": "https://kmerhosting.com/pricing"
      },
      {
        "label": "Support",
        "href": "https://kmerhosting.com/support"
      },
      {
        "label": "Status",
        "href": "https://status.kmerhosting.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Client area",
      "href": "https://kmerhosting.com/dashboard"
    }
  },
  "footer": {
    "socials": {},
    "links": [
      {
        "header": "Platform",
        "items": [
          {
            "label": "Pricing",
            "href": "https://kmerhosting.com/pricing"
          },
          {
            "label": "Support",
            "href": "https://kmerhosting.com/support"
          },
          {
            "label": "Status",
            "href": "https://status.kmerhosting.com"
          }
        ]
      },
      {
        "header": "Legal",
        "items": [
          {
            "label": "Terms",
            "href": "https://kmerhosting.com/terms-of-service"
          },
          {
            "label": "Privacy",
            "href": "https://kmerhosting.com/privacy-policy"
          },
          {
            "label": "Refund policy",
            "href": "https://kmerhosting.com/refund-policy"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy"
    ],
    "display": "header"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "pages": [
          "index",
          "quickstart",
          "account/create-account",
          "account/email-verification",
          "account/kyc",
          "account/account-status"
        ]
      },
      {
        "group": "Products",
        "icon": "server",
        "pages": [
          "products/shared-hosting",
          "products/vps",
          "products/domains",
          "products/custom-hosting"
        ]
      },
      {
        "group": "Billing",
        "icon": "receipt",
        "pages": [
          "billing/overview",
          "billing/account-credit",
          "billing/orders",
          "billing/invoices",
          "billing/renewals",
          "billing/refunds"
        ]
      },
      {
        "group": "Deployment guides",
        "icon": "upload-cloud",
        "pages": [
          "guides/deploy-website",
          "guides/shared-hosting-stacks",
          "guides/vps-stacks",
          "guides/dns-management",
          "guides/ssl-certificates",
          "guides/backups"
        ]
      },
      {
        "group": "Customer guides",
        "icon": "book-open",
        "pages": [
          "guides/domain-availability",
          "guides/checkout",
          "guides/service-management",
          "guides/auto-renewal",
          "guides/support-ticket",
          "guides/email-configuration"
        ]
      },
      {
        "group": "API",
        "icon": "braces",
        "pages": [
          "api/overview",
          "api/authentication",
          "api/errors",
          "api/endpoints"
        ]
      },
      {
        "group": "API reference",
        "icon": "terminal",
        "openapi": {
          "source": "openapi.json",
          "directory": "api-reference"
        }
      },
      {
        "group": "Operations",
        "icon": "activity",
        "pages": [
          "operations/status-page",
          "operations/incidents",
          "operations/maintenance"
        ]
      },
      {
        "group": "Troubleshooting",
        "icon": "wrench",
        "pages": [
          "troubleshooting/login",
          "troubleshooting/payment",
          "troubleshooting/domain-dns",
          "troubleshooting/vps-access",
          "troubleshooting/shared-hosting"
        ]
      },
      {
        "group": "Legal",
        "icon": "scale",
        "pages": [
          "legal/terms",
          "legal/privacy",
          "legal/refund-policy",
          "legal/sla",
          "legal/cookie-policy",
          "legal/ai-usage-policy"
        ]
      }
    ]
  }
}
